# Copy this file to .env.local and fill in your actual values.

# === Supabase ===
# From your Supabase project: Settings → API
# https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === Admin login (REQUIRED) ===
# Single-admin credentials used by /login and /sys-monitor/login.
# Without these the app cannot be logged into.
ADMIN_USERNAME=changeme
ADMIN_PASSWORD=change-this-to-a-strong-password

# === Session signing (recommended) ===
# Secret used to HMAC-sign the auth session cookie. If unset, the app falls
# back to ADMIN_PASSWORD (works, but rotating the password logs everyone out).
# Use a long random string, e.g. `openssl rand -hex 32`.
AUTH_SECRET=

# === Public stats page ===
# Password gating the public /stats view.
NEXT_PUBLIC_STATS_PSW=password-for-the-stats
